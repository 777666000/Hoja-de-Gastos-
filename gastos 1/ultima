function renderHist(){const keys=wkSorted().reverse();document.getElementById('histBadge').textContent=keys.length+' semana'+(keys.length!==1?'s':'');const el=document.getElementById('histContent');if(!keys.length){el.innerHTML=`<div class="empty"><div class="e2">📭</div>Sin historial aún</div>`;return;}el.innerHTML=keys.map(k=>{const wk=ST.weeks[k];const sal=parseFloat(wk.salario)||0;const gst=wk.expenses.reduce((s,e)=>s+(parseFloat(e.amount)||0),0);const oci=(wk.ocio||[]).reduce((s,o)=>s+(parseFloat(o.amount)||0),0);const on=distOn(k);const tr2=on?sal*0.10:0,inv2=on?sal*0.20:0;const total=gst+oci+tr2+inv2,libre=sal-total;const pct=sal>0?Math.min(100,total/sal*100):0;const isCur=k===TODAY;const did='D'+k.replace(/-/g,'');const rows=[...wk.expenses.map(e=>`<div class="wdr"><span>${e.icon} ${e.name}</span><span>${E(parseFloat(e.amount)||0)}</span></div>`),...(wk.ocio||[]).map(o=>`<div class="wdr"><span>${o.icon} ${o.name}${o.motivo?' · '+o.motivo:''}</span><span>${E(parseFloat(o.amount)||0)}</span></div>`),on?`<div class="wdr"><span>💹 Trade Republic</span><span>${E(tr2)}</span></div>`:'',on?`<div class="wdr"><span>📈 Inversiones</span><span>${E(inv2)}</span></div>`:''].filter(Boolean).join('');return`<div class="wc${isCur?' cur':''}" onclick="togDet('${did}')"><div class="wh2"><span class="wd">📅 ${wkLabel(k)} · S${wkNum(k)}</span>${isCur?'<span class="wcb">Esta semana</span>':''}</div><div class="wns"><div class="wn"><div class="wnv" style="color:var(--acc)">${E(sal)}</div><div class="wnl">Salario</div></div><div class="wn"><div class="wnv" style="color:var(--red)">${E(gst+oci)}</div><div class="wnl">Gastado</div></div><div class="wn"><div class="wnv" style="color:${libre>=0?'var(--grn)':'var(--red)'}">${E(libre)}</div><div class="wnl">Libre</div></div></div><div class="wbg"><div class="wbf" style="width:${pct}%"></div></div>${rows?`<div class="wdet" id="${did}">${rows}</div>`:''}</div>`;}).join('');}
function togDet(id){const e=document.getElementById(id);if(e)e.classList.toggle('open');}

function renderStats(){const keys=wkSorted();const el=document.getElementById('statsContent');if(!keys.length){el.innerHTML=`<div class="empty"><div class="e2">📈</div>Añade datos para ver estadísticas</div>`;return;}let tSal=0,tGst=0,tOci=0,tLib=0,best=null,worst=null;const catMap={},ocioMap={};keys.forEach(k=>{const wk=ST.weeks[k];const sal=parseFloat(wk.salario)||0;const gst=wk.expenses.reduce((s,e)=>s+(parseFloat(e.amount)||0),0);const oci=(wk.ocio||[]).reduce((s,o)=>s+(parseFloat(o.amount)||0),0);const on=distOn(k);const inv=on?sal*0.30:0;const lib=sal-gst-oci-inv;tSal+=sal;tGst+=gst;tOci+=oci;tLib+=lib;if(!best||lib>best.lib)best={key:k,lib};if(!worst||lib<worst.lib)worst={key:k,lib};wk.expenses.forEach(e=>{catMap[e.name]=(catMap[e.name]||0)+(parseFloat(e.amount)||0);});(wk.ocio||[]).forEach(o=>{ocioMap[o.name]=(ocioMap[o.name]||0)+(parseFloat(o.amount)||0);});});const n=keys.length;document.getElementById('statsBadge').textContent=n+' semana'+(n!==1?'s':'');const cats=Object.entries(catMap).sort((a,b)=>b[1]-a[1]).slice(0,6);const maxC=cats[0]?cats[0][1]:1;const ocios=Object.entries(ocioMap).sort((a,b)=>b[1]-a[1]).slice(0,4);el.innerHTML=`<div class="sg"><div class="sc"><div class="scl">Salario medio</div><div class="scv" style="color:var(--acc)">${E(tSal/n)}</div></div><div class="sc"><div class="scl">Libre medio</div><div class="scv" style="color:${tLib/n>=0?'var(--grn)':'var(--red)'}">${E(tLib/n)}</div></div><div class="sc"><div class="scl">Gasto medio/sem</div><div class="scv" style="color:var(--red)">${E(tGst/n)}</div></div><div class="sc"><div class="scl">Total ocio</div><div class="scv" style="color:var(--blu)">${E(tOci)}</div></div>${best?`<div class="sc"><div class="scl">✅ Mejor semana</div><div class="scv" style="color:var(--grn);font-size:13px">${wkLabel(best.key)}</div><div style="font-size:10px;color:var(--mut);margin-top:3px;font-family:var(--mono)">${E(best.lib)} libre</div></div>`:''}${worst&&worst.key!==best?.key?`<div class="sc"><div class="scl">⚠️ Peor semana</div><div class="scv" style="color:var(--red);font-size:13px">${wkLabel(worst.key)}</div><div style="font-size:10px;color:var(--mut);margin-top:3px;font-family:var(--mono)">${E(worst.lib)} libre</div></div>`:''}</div>${cats.length?`<div class="sec"><div class="stl">En qué más gastas</div><div style="background:var(--surf);border:1px solid var(--bdr);border-radius:14px;padding:12px 14px">${cats.map(([n2,v])=>`<div class="cr"><span>${n2}</span><div style="display:flex;align-items:center;gap:6px;flex-shrink:0"><div class="cbw"><div class="cbf" style="width:${v/maxC*100}%"></div></div><span style="font-family:var(--mono);font-size:12px">${E(v)}</span></div></div>`).join('')}</div></div>`:''}${ocios.length?`<div class="sec"><div class="stl">Ocio más frecuente</div><div style="background:var(--surf);border:1px solid var(--bdr);border-radius:14px;padding:12px 14px">${ocios.map(([n2,v])=>`<div class="cr"><span>🎬 ${n2}</span><span style="font-family:var(--mono);font-size:12px;color:var(--blu)">${E(v)}</span></div>`).join('')}</div></div>`:'`}}`;}

function renderGoals(){const done=ST.goals.filter(g=>g.done).length;document.getElementById('goalBadge').textContent=done+' cumplido'+(done!==1?'s':'');document.getElementById('totSaved').textContent=E(ST.totalSaved||0);const el=document.getElementById('goalsList');if(!ST.goals.length){el.innerHTML=`<div class="empty"><div class="e2">🎯</div>Sin objetivos aún<br>Crea el primero abajo</div>`;return;}const sorted=[...ST.goals].sort((a,b)=>a.done&&!b.done?1:!a.done&&b.done?-1:0);const firstActive=sorted.findIndex(g=>!g.done);el.innerHTML=sorted.map((g,i)=>{const tgt=parseFloat(g.target)||1,sv=parseFloat(g.saved)||0;const pct=Math.min(100,sv/tgt*100);const isActive=i===firstActive;return`<div class="gc${g.done?' done':''}${isActive?' ag':''}"><div class="gch"><span class="gci">${g.icon}</span><div><div class="gct">${g.name}${isActive?' 👈':''}</div><div class="gcs">Meta: ${E(tgt)}</div></div></div><div class="gpr"><span class="gpl">Ahorrado</span><span class="gpv">${E(sv)} / ${E(tgt)} · ${pct.toFixed(0)}%</span></div><div class="gbb"><div class="gbf" style="width:${pct}%"></div></div>${g.done?`<div class="gdb">✅ Completado el ${g.completedDate||'—'}</div>`:`<div style="display:flex;gap:8px;margin-top:11px"><button class="btn btn-g" style="font-size:12px;padding:8px" onclick="openGoalEdit(${g.id})">Editar</button><button class="btn btn-gr" style="font-size:12px;padding:8px" onclick="openGoalAddM(${g.id})">+ Añadir ahorro</button></div>`}</div>`;}).join('');}

function openAddGoal(){eGoalId=null;eGoalEmoji='💰';document.getElementById('mGoalT').textContent='Nuevo objetivo';['mGoalN','mGoalTgt','mGoalSv'].forEach(id=>document.getElementById(id).value='');buildEG('mGoalE',EG,eGoalEmoji,'pickGoalE');document.getElementById('mGoalAc').innerHTML=`<button class="btn btn-g" onclick="closeAll()">Cancelar</button><button class="btn btn-p" onclick="saveGoal()">Crear</button>`;openM('moGoal');setTimeout(()=>document.getElementById('mGoalN').focus(),320);}
function openGoalEdit(id){const g=ST.goals.find(x=>x.id===id);if(!g)return;eGoalId=id;eGoalEmoji=g.icon;document.getElementById('mGoalT').textContent='Editar objetivo';document.getElementById('mGoalN').value=g.name;document.getElementById('mGoalTgt').value=g.target;document.getElementById('mGoalSv').value=g.saved;buildEG('mGoalE',EG,eGoalEmoji,'pickGoalE');document.getElementById('mGoalAc').innerHTML=`<button class="btn btn-d" onclick="delGoal(${id});closeAll()">Eliminar</button><button class="btn btn-p" onclick="saveGoal()">Guardar</button>`;openM('moGoal');}
function pickGoalE(e,el){eGoalEmoji=e;document.querySelectorAll('#mGoalE .eb').forEach(b=>b.classList.remove('sel'));el.classList.add('sel');}
function saveGoal(){const name=document.getElementById('mGoalN').value.trim();const tgt=parseFloat(document.getElementById('mGoalTgt').value)||0;const sv=parseFloat(document.getElementById('mGoalSv').value)||0;if(!name||!tgt){document.getElementById('mGoalN').focus();return;}if(eGoalId!==null){const g=ST.goals.find(x=>x.id===eGoalId);if(g){ST.totalSaved=Math.max(0,(ST.totalSaved||0)+(sv-(g.saved||0)));g.name=name;g.target=tgt;g.icon=eGoalEmoji;g.saved=sv;if(sv>=tgt&&!g.done){g.done=true;g.completedDate=new Date().toLocaleDateString('es-ES');}else if(sv<tgt){g.done=false;delete g.completedDate;}}}else{const g={id:ST.nextGoalId++,name,target:tgt,saved:sv,icon:eGoalEmoji,done:false};if(sv>=tgt){g.done=true;g.completedDate=new Date().toLocaleDateString('es-ES');}ST.goals.push(g);ST.totalSaved=(ST.totalSaved||0)+sv;}closeAll();persist();renderGoals();}
function delGoal(id){const g=ST.goals.find(x=>x.id===id);if(g)ST.totalSaved=Math.max(0,(ST.totalSaved||0)-(g.saved||0));ST.goals=ST.goals.filter(x=>x.id!==id);persist();renderGoals();}
function openGoalAddM(id){addGoalId=id;const g=ST.goals.find(x=>x.id===id);if(!g)return;document.getElementById('mGAddT').textContent=`Añadir a "${g.name}"`;document.getElementById('mGAddA').value='';openM('moGAdd');setTimeout(()=>document.getElementById('mGAddA').focus(),320);}
function saveGoalAdd(){const amt=parseFloat(document.getElementById('mGAddA').value)||0;if(!amt)return;const g=ST.goals.find(x=>x.id===addGoalId);if(!g)return;g.saved=(g.saved||0)+amt;ST.totalSaved=(ST.totalSaved||0)+amt;if(g.saved>=g.target&&!g.done){g.done=true;g.completedDate=new Date().toLocaleDateString('es-ES');}closeAll();persist();renderGoals();}

function openM(id){document.getElementById(id).classList.add('open');}
function closeAll(){document.querySelectorAll('.mo').forEach(m=>m.classList.remove('open'));eExpId=null;eOcioId=null;eGoalId=null;addGoalId=null;}
document.querySelectorAll('.mo').forEach(ov=>ov.addEventListener('click',e=>{if(e.target===ov)closeAll();}));

if('serviceWorker' in navigator){const swCode=`const CACHE='gastos-v1';self.addEventListener('install',e=>{self.skipWaiting();});self.addEventListener('activate',e=>{self.clients.claim();});self.addEventListener('fetch',e=>{if(e.request.method!=='GET')return;e.respondWith(caches.match(e.request).then(r=>r||fetch(e.request)));});`;const blob=new Blob([swCode],{type:'application/javascript'});navigator.serviceWorker.register(URL.createObjectURL(blob)).catch(()=>{});}

boot();
</script>
</body>
