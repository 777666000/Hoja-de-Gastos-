<script>
const DB_NAME='GastosDB',DB_VER=1,STORE='state';
let db=null;
function openDB(){return new Promise((res,rej)=>{const req=indexedDB.open(DB_NAME,DB_VER);req.onupgradeneeded=e=>{e.target.result.createObjectStore(STORE,{keyPath:'id'})};req.onsuccess=e=>{db=e.target.result;res(db)};req.onerror=e=>rej(e.target.error)});}
function dbGet(key){return new Promise((res,rej)=>{const tx=db.transaction(STORE,'readonly');const req=tx.objectStore(STORE).get(key);req.onsuccess=()=>res(req.result?req.result.data:null);req.onerror=e=>rej(e.target.error)});}
function dbSet(key,data){return new Promise((res,rej)=>{const tx=db.transaction(STORE,'readwrite');const req=tx.objectStore(STORE).put({id:key,data});req.onsuccess=()=>res();req.onerror=e=>rej(e.target.error)});}

const MO=['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
const EE=['🍔','🛒','🥡','☕','🍕','🍺','🚬','🍿','🧃','💊','🚗','⛽','👕','👟','🧴','📱','💈','🎮','✂️','🏋️','📚','🏠','🔧','🐾','🧹','💻','🎓','💉'];
const EO=['🎬','🎵','🎮','🍻','🎳','🎭','🏖️','⚽','🎪','🥳','🎉','🏄','🎯','🃏','🎲','🏋️','🎸','🍽️','🎡','🚀'];
const EG=['🏠','✈️','🚗','💻','📱','👟','🎓','💍','🐾','🛋️','🌍','🎸','⛵','🏋️','💰','🔑','🎁','🌿','🏕️','💊'];

function thuKey(d){const b=new Date(d||Date.now());const diff=(b.getDay()-4+7)%7;const t=new Date(b);t.setDate(b.getDate()-diff);t.setHours(0,0,0,0);return t.toISOString().slice(0,10);}
const TODAY=thuKey();
function wkLabel(k){const t=new Date(k+'T00:00:00');const w=new Date(t);w.setDate(t.getDate()+6);return`${t.getDate()} ${MO[t.getMonth()]} – ${w.getDate()} ${MO[w.getMonth()]}`;}
function fmt(n){const v=Math.abs(n);const s=(v%1===0?v.toFixed(0):v.toFixed(2)).replace('.',',');return(n<0?'-':'')+s;}
function E(n){return'€'+fmt(n);}
function wkSorted(){return Object.keys(ST.weeks).sort();}
function wkNum(k){return wkSorted().indexOf(k)+1;}
function distOn(k){if(!ST.distActive)return false;return new Date(k+'T00:00:00')>=new Date(ST.distStart+'T00:00:00');}

function defWk(){return{salario:0,expenses:[{id:1,name:'Comida',icon:'🍔',amount:0},{id:2,name:'Tabaco',icon:'🚬',amount:0},{id:3,name:'Snacks',icon:'🍿',amount:0}],ocio:[],nextId:4};}
function defState(){const base=new Date();const dtn=(4-base.getDay()+7)%7||7;const ds=new Date(base);ds.setDate(base.getDate()+dtn+7);return{distActive:false,distStart:ds.toISOString().slice(0,10),weeks:{[TODAY]:defWk()},goals:[],nextGoalId:1,totalSaved:0};}

let ST=defState();
let saveTimer=null;

function setSdot(state){const d=document.getElementById('sdot');if(!d)return;d.className='sdot'+(state==='busy'?' busy':state==='err'?' err':'');}

async function persist(){clearTimeout(saveTimer);setSdot('busy');saveTimer=setTimeout(async()=>{try{await dbSet('main',ST);setSdot('ok');setTimeout(()=>setSdot(''),2000);}catch(e){console.error('Save failed',e);setSdot('err');try{localStorage.setItem('gastos_backup',JSON.stringify(ST));}catch(_){}}},500);}

async function boot(){await openDB();let saved=await dbGet('main');if(!saved){try{const raw=localStorage.getItem('gastos_backup');if(raw)saved=JSON.parse(raw);}catch(_){}}if(saved){ST=saved;}if(!ST.weeks[TODAY]){const keys=wkSorted();const last=keys.length?ST.weeks[keys[keys.length-1]]:null;const nw=defWk();if(last){nw.expenses=last.expenses.map(e=>({...e,amount:0}));nw.nextId=last.nextId;}ST.weeks[TODAY]=nw;await persist();}document.getElementById('loading').classList.add('hide');document.getElementById('app').style.display='';render();}

let currentTab='semana';
function goTab(name){currentTab=name;document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));document.querySelectorAll('.nb').forEach(b=>b.classList.remove('on'));document.getElementById('pg-'+name).classList.add('active');document.querySelector(`[data-p="${name}"]`).classList.add('on');if(name==='historial')renderHist();if(name==='stats')renderStats();if(name==='objetivos')renderGoals();}

function render(){const wk=ST.weeks[TODAY];const sal=parseFloat(wk.salario)||0;document.getElementById('wkBadge').innerHTML=wkLabel(TODAY)+' <span class="sdot" id="sdot"></span>';document.getElementById('wkNum').textContent='S'+wkNum(TODAY);const acum=Object.values(ST.weeks).reduce((s,w)=>s+(parseFloat(w.salario)||0),0);document.getElementById('salAcum').textContent=E(acum);const inp=document.getElementById('salInp');if(document.activeElement!==inp)inp.value=wk.salario||'';const on=ST.distActive;document.getElementById('distTog').classList.toggle('on',on);document.getElementById('distLbl').textContent=on?'Activa':'Desactivada';const dn=document.getElementById('distNote');if(!on){const sd=new Date(ST.distStart+'T00:00:00');dn.innerHTML=`<div class="dist-note">⏳ Inicio planificado: <strong>${sd.getDate()} ${MO[sd.getMonth()]} ${sd.getFullYear()}</strong> — controlando el ritmo mientras<div class="daterow"><label>Cambiar fecha:</label><input type="date" class="dinp" id="dInp" value="${ST.distStart}"></div></div>`;document.getElementById('dInp').onchange=function(){if(this.value){ST.distStart=this.value;persist();render();}};}else{dn.innerHTML='';}const tr=on?sal*0.10:0,bolsa=on?sal*0.10:0,ropa=on?sal*0.10:0;document.getElementById('dTR').textContent=E(tr);document.getElementById('dBo').textContent=E(bolsa);document.getElementById('dRo').textContent=E(ropa);['cTR','cBo','cRo'].forEach(id=>document.getElementById(id).classList.toggle('off',!on));const el=document.getElementById('expList');el.innerHTML='';let totG=0;wk.expenses.forEach(exp=>{const amt=parseFloat(exp.amount)||0;totG+=amt;const sw=document.createElement('div');sw.className='sw';sw.innerHTML=`<div class="dbg" onclick="delExp(${exp.id})">🗑</div><div class="er" onclick="openEditExp(${exp.id})"><span class="ei">${exp.icon}</span><div class="einfo"><div class="en">${exp.name}</div><div class="es">${sal>0?(amt/sal*100).toFixed(1)+'% del salario':'—'}</div></div><div class="ea"><span class="esy">€</span><input class="einp" type="number" inputmode="decimal" value="${exp.amount||''}" placeholder="0" step="0.01" data-id="${exp.id}" onclick="event.stopPropagation()"></div></div>`;el.appendChild(sw);attachSwipe(sw);const i=sw.querySelector('.einp');i.addEventListener('input',()=>{const x=wk.expenses.find(e=>e.id===exp.id);if(x){x.amount=parseFloat(i.value)||0;persist();renderRes();}});i.addEventListener('change',render);});const ol=document.getElementById('ocioList');ol.innerHTML='';let totO=0;(wk.ocio||[]).forEach(oc=>{const amt=parseFloat(oc.amount)||0;totO+=amt;const sw=document.createElement('div');sw.className='sw';sw.innerHTML=`<div class="dbg" onclick="delOcio(${oc.id})">🗑</div><div class="or2" onclick="openEditOcio(${oc.id})"><span class="oi">${oc.icon}</span><div class="oin"><div class="on2">${oc.name}</div><div class="om">${oc.motivo||'Sin descripción'}</div></div><div class="oe">${E(amt)}</div></div>`;ol.appendChild(sw);attachSwipe(sw);});renderRes(sal,totG,tr,bolsa+ropa,totO);}

function attachSwipe(wrap){let sx=0;const r=wrap.querySelector('.er,.or2');if(!r)return;r.addEventListener('touchstart',e=>{sx=e.touches[0].clientX;},{passive:true});r.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-sx;if(dx<-40)wrap.classList.add('swiped');else if(dx>10)wrap.classList.remove('swiped');},{passive:true});}

function renderRes(sal,totG,tr,inv,totO){const wk=ST.weeks[TODAY];sal=sal??(parseFloat(wk.salario)||0);totG=totG??wk.expenses.reduce((s,e)=>s+(parseFloat(e.amount)||0),0);const on=ST.distActive;tr=tr??(on?sal*0.10:0);inv=inv??(on?sal*0.20:0);totO=totO??(wk.ocio||[]).reduce((s,o)=>s+(parseFloat(o.amount)||0),0);const total=totG+totO+tr+inv,libre=sal-total;const rows=[{l:'Salario',c:'#7c6ffa',v:sal,p:100,hl:true},{l:'Gastos variables',c:'#f87171',v:totG,p:sal>0?totG/sal*100:0},{l:'Ocio',c:'#60a5fa',v:totO,p:sal>0?totO/sal*100:0},...(on?[{l:'Trade Republic 10%',c:'#7c6ffa',v:tr,p:sal>0?tr/sal*100:0},{l:'Inversiones 20%',c:'#4ade80',v:inv,p:sal>0?inv/sal*100:0}]:[]),{l:'LIBRE',c:'#4ade80',v:libre,p:sal>0?libre/sal*100:0,libre:true}];document.getElementById('resCard').innerHTML=rows.map(r=>`<div class="rrow ${r.hl?'hl':''} ${r.libre?'lr':''}"><div class="rl2"><div class="rd" style="background:${r.c}"></div><span class="rlb">${r.l}</span></div><div class="rr2"><div class="rev" style="color:${r.libre&&libre<0?'var(--red)':r.libre?'#4ade80':'inherit'}">${E(r.v)}</div><div class="rpc">${r.p.toFixed(1)}%</div></div></div>`).join('');const pg=n=>sal>0?Math.min(100,Math.max(0,n/sal*100)):0;document.getElementById('segG').style.width=pg(totG)+'%';document.getElementById('segO').style.width=pg(totO)+'%';document.getElementById('segT').style.width=pg(tr)+'%';document.getElementById('segI').style.width=pg(inv)+'%';document.getElementById('progLbl').textContent=sal>0?`${(total/sal*100).toFixed(0)}% usado`:'—';}

function toggleDist(){ST.distActive=!ST.distActive;persist();render();}

let eExpId=null,eExpEmoji='🛒',eOcioId=null,eOcioEmoji='🎬',eGoalId=null,eGoalEmoji='💰',addGoalId=null;
function buildEG(cid,list,sel,fn){document.getElementById(cid).innerHTML=list.map(e=>`<div class="eb${e===sel?' sel':''}" onclick="${fn}('${e}',this)">${e}</div>`).join('');}

function openAddExp(){eExpId=null;eExpEmoji='🛒';document.getElementById('mExpT').textContent='Nuevo gasto';document.getElementById('mExpN').value='';document.getElementById('mExpA').value='';buildEG('mExpE',EE,eExpEmoji,'pickExpE');document.getElementById('mExpAc').innerHTML=`<button class="btn btn-g" onclick="closeAll()">Cancelar</button><button class="btn btn-p" onclick="saveExp()">Añadir</button>`;openM('moExp');setTimeout(()=>document.getElementById('mExpN').focus(),320);}
function openEditExp(id){const exp=ST.weeks[TODAY].expenses.find(e=>e.id===id);if(!exp)return;eExpId=id;eExpEmoji=exp.icon;document.getElementById('mExpT').textContent='Editar gasto';document.getElementById('mExpN').value=exp.name;document.getElementById('mExpA').value=exp.amount||'';buildEG('mExpE',EE,eExpEmoji,'pickExpE');document.getElementById('mExpAc').innerHTML=`<button class="btn btn-d" onclick="delExp(${id});closeAll()">Eliminar</button><button class="btn btn-p" onclick="saveExp()">Guardar</button>`;openM('moExp');}
function pickExpE(e,el){eExpEmoji=e;document.querySelectorAll('#mExpE .eb').forEach(b=>b.classList.remove('sel'));el.classList.add('sel');}
function saveExp(){const name=document.getElementById('mExpN').value.trim();const amt=parseFloat(document.getElementById('mExpA').value)||0;if(!name){document.getElementById('mExpN').focus();return;}const wk=ST.weeks[TODAY];if(eExpId!==null){const x=wk.expenses.find(e=>e.id===eExpId);if(x){x.name=name;x.icon=eExpEmoji;x.amount=amt;}}else{wk.expenses.push({id:wk.nextId++,name,icon:eExpEmoji,amount:amt});}closeAll();persist();render();}
function delExp(id){ST.weeks[TODAY].expenses=ST.weeks[TODAY].expenses.filter(e=>e.id!==id);persist();render();}

function openAddOcio(){eOcioId=null;eOcioEmoji='🎬';document.getElementById('mOcioT').textContent='Añadir ocio';['mOcioN','mOcioM','mOcioA'].forEach(id=>document.getElementById(id).value='');buildEG('mOcioE',EO,eOcioEmoji,'pickOcioE');document.getElementById('mOcioAc').innerHTML=`<button class="btn btn-g" onclick="closeAll()">Cancelar</button><button class="btn btn-p" onclick="saveOcio()">Añadir</button>`;openM('moOcio');setTimeout(()=>document.getElementById('mOcioN').focus(),320);}
function openEditOcio(id){if(!ST.weeks[TODAY].ocio)ST.weeks[TODAY].ocio=[];const oc=ST.weeks[TODAY].ocio.find(o=>o.id===id);if(!oc)return;eOcioId=id;eOcioEmoji=oc.icon;document.getElementById('mOcioT').textContent='Editar ocio';document.getElementById('mOcioN').value=oc.name;document.getElementById('mOcioM').value=oc.motivo||'';document.getElementById('mOcioA').value=oc.amount||'';buildEG('mOcioE',EO,eOcioEmoji,'pickOcioE');document.getElementById('mOcioAc').innerHTML=`<button class="btn btn-d" onclick="delOcio(${id});closeAll()">Eliminar</button><button class="btn btn-p" onclick="saveOcio()">Guardar</button>`;openM('moOcio');}
function pickOcioE(e,el){eOcioEmoji=e;document.querySelectorAll('#mOcioE .eb').forEach(b=>b.classList.remove('sel'));el.classList.add('sel');}
function saveOcio(){const name=document.getElementById('mOcioN').value.trim();const motivo=document.getElementById('mOcioM').value.trim();const amt=parseFloat(document.getElementById('mOcioA').value)||0;if(!name){document.getElementById('mOcioN').focus();return;}const wk=ST.weeks[TODAY];if(!wk.ocio)wk.ocio=[];if(eOcioId!==null){const x=wk.ocio.find(o=>o.id===eOcioId);if(x){x.name=name;x.motivo=motivo;x.icon=eOcioEmoji;x.amount=amt;}}else{wk.ocio.push({id:wk.nextId++,name,motivo,icon:eOcioEmoji,amount:amt});}closeAll();persist();render();}
function delOcio(id){if(!ST.weeks[TODAY].ocio)return;ST.weeks[TODAY].ocio=ST.weeks[TODAY].ocio.filter(o=>o.id!==id);persist();render();}

document.getElementById('salInp').addEventListener('input',function(){ST.weeks[TODAY].salario=parseFloat(this.value)||0;persist();renderRes();});
document.getElementById('salInp').addEventListener('change',render);
